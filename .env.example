# Firebase — obtener de Firebase Console > Project Settings > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth — los IDs salen de google-services.json (client[].oauth_client)
#
# WEB CLIENT ID (el ÚNICO usado en JS por @react-native-google-signin como webClientId):
#   = el client con "client_type": 3 DENTRO de client[].oauth_client.
#   OJO: NO uses el de services.appinvite_service.other_platform_oauth_client
#        (también es client_type 3 pero apuntar ahí causa DEVELOPER_ERROR código 10).
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=
# ANDROID CLIENT ID ("client_type": 1). Tras migrar a google-signin ya NO se usa en
# JS (lo resuelve el SDK nativo desde google-services.json). Se deja documentado.
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=
# iOS CLIENT ID: para build nativo iOS.
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=

# Backend API
# Desarrollo local iOS:       http://localhost:3000/api/v1
# Desarrollo local Android:   http://10.0.2.2:3000/api/v1  (emulador) o http://TU_IP:3000/api/v1 (dispositivo real)
# Producción:                 https://tu-proyecto.railway.app/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
