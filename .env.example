# Firebase — obtener de Firebase Console > Project Settings > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth — obtener de Google Cloud Console > Credentials
# Web Client ID: para expo-auth-session en Expo Go
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android Client ID: para build nativo Android
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# iOS Client ID: para build nativo iOS
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Backend API
# Desarrollo local iOS:       http://localhost:3000/api/v1
# Desarrollo local Android:   http://10.0.2.2:3000/api/v1  (emulador) o http://TU_IP:3000/api/v1 (dispositivo real)
# Producción:                 https://tu-proyecto.railway.app/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
